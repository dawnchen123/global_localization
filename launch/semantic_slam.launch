<launch>
  <arg name="config" default="$(find fast_livo2_global_localization)/config/semantic_slam.yaml"/>
  <arg name="rangenet_adapter_config" default="$(find fast_livo2_global_localization)/config/rangenet_geometry_adapter.yaml"/>
  <arg name="segformer_projector_config" default="$(find fast_livo2_global_localization)/config/segformer_mask_projector.yaml"/>
  <arg name="run_rangenet_adapter" default="true"/>
  <arg name="run_semantic_mapper" default="true"/>
  <arg name="run_segformer_projector" default="false"/>
  <arg name="odom_topic" default="/aft_mapped_to_init"/>
  <arg name="rangenet_semantic_topic" default="/rangenet/semantic_points"/>
  <arg name="rangenet_adapter_input_topic" default="/cloud_registered"/>
  <arg name="rangenet_semantic_cloud_in_map_frame" default="true"/>
  <arg name="lidar_label_mode" default="internal"/>
  <arg name="segformer_mask_topic" default="/segformer/label_mask"/>
  <arg name="segformer_projected_topic" default="/segformer/projected_semantic_points"/>
  <arg name="segformer_projector_cloud_topic" default="/rangenet/semantic_points"/>

  <!--
    Start FAST-LIVO2 outside this launch.

    If RangeNet++ is not installed, run_rangenet_adapter=true creates a local
    geometric fallback publisher:
      /cloud_registered -> /rangenet/semantic_points

    If real RangeNet++ is installed, launch with:
      run_rangenet_adapter:=false rangenet_semantic_cloud_in_map_frame:=false

    Expected stage-1 topics:
      /aft_mapped_to_init
      /rangenet/semantic_points   sensor_msgs/PointCloud2 with x/y/z/label[/confidence]

    Optional stage-2 topics:
      /segformer/label_mask       sensor_msgs/Image mono8
      point cloud topic configured in segformer_mask_projector.yaml
  -->

  <node if="$(arg run_rangenet_adapter)"
        pkg="fast_livo2_global_localization"
        type="rangenet_geometry_adapter_node"
        name="rangenet_geometry_adapter"
        output="screen">
    <rosparam file="$(arg rangenet_adapter_config)" command="load"/>
    <param name="input_cloud_topic" value="$(arg rangenet_adapter_input_topic)"/>
    <param name="output_cloud_topic" value="$(arg rangenet_semantic_topic)"/>
  </node>

  <node if="$(arg run_semantic_mapper)"
        pkg="fast_livo2_global_localization"
        type="semantic_voxel_mapper_node"
        name="semantic_voxel_mapper"
        output="screen">
    <rosparam file="$(arg config)" command="load"/>
    <param name="odom_topic" value="$(arg odom_topic)"/>
    <param name="lidar_semantic_cloud_topic" value="$(arg rangenet_semantic_topic)"/>
    <param name="lidar_cloud_in_map_frame" value="$(arg rangenet_semantic_cloud_in_map_frame)"/>
    <param name="lidar_label_mode" value="$(arg lidar_label_mode)"/>
    <param name="segformer_semantic_cloud_topic" value="$(arg segformer_projected_topic)"/>
    <param name="subscribe_segformer_semantic_cloud" value="$(arg run_segformer_projector)"/>
  </node>

  <node if="$(arg run_segformer_projector)"
        pkg="fast_livo2_global_localization"
        type="segformer_mask_projector_node"
        name="segformer_mask_projector"
        output="screen">
    <rosparam file="$(arg segformer_projector_config)" command="load"/>
    <param name="cloud_topic" value="$(arg segformer_projector_cloud_topic)"/>
    <param name="mask_topic" value="$(arg segformer_mask_topic)"/>
    <param name="output_topic" value="$(arg segformer_projected_topic)"/>
  </node>
</launch>
