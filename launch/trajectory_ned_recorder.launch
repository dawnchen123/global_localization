<launch>
  <arg name="config" default="$(find fast_livo2_global_localization)/config/trajectory_ned_recorder.yaml"/>
  <arg name="fast_livo_odom_topic" default="/aft_mapped_to_init"/>
  <arg name="fused_odom_topic" default="/semantic_graph_corrected_odom"/>
  <arg name="output_dir" default="/tmp/trajectory_records"/>

  <node pkg="fast_livo2_global_localization"
        type="trajectory_ned_recorder.py"
        name="trajectory_ned_recorder"
        output="screen">
    <rosparam file="$(arg config)" command="load"/>
    <param name="fast_livo_odom_topic" value="$(arg fast_livo_odom_topic)"/>
    <param name="fused_odom_topic" value="$(arg fused_odom_topic)"/>
    <param name="output_dir" value="$(arg output_dir)"/>
  </node>
</launch>
